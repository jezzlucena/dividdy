# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/dividdy

# Exchange Rate API (free tier from exchangerate-api.com)
EXCHANGE_RATE_API_KEY=your_api_key_here

# Addresses allowed to access the backend, comma separated - no spaces
HOST_ALLOWLIST="http://localhost:8091,https://www.dividdy.com,https://dividdy.com"
